# Copy to .env if you want to override defaults.
# `make dev` works without any of these set.

# ---- mock-discord ----
# Where mock-discord delivers slash command interactions.
# Override if your bot listens on a different host/port.
BOT_WEBHOOK_URL=http://host.docker.internal:8080/interactions

# ---- mock-platform ----
# How long the "video pipeline" pretends to take, in seconds.
# Real one is 30s-5min. Lower this to iterate faster.
PLATFORM_DELAY_SECONDS=60

# ---- mock-llm ----
# When 1, mock-llm returns prose unless the prompt explicitly asks for
# structured output. When 0, it always returns parseable JSON.
LLM_ADVERSARIAL=1

# ---- ports (only change if they collide with something on your machine) ----
MOCK_DISCORD_PORT=7001
MOCK_PLATFORM_PORT=7002
MOCK_LLM_PORT=7003
